{
  "$id": "schemas/nodes/genes.GencodeGene.json",
  "db_collection_name": "genes",
  "allOf": [
    {
      "$ref": "node.base.json"
    },
    {
      "type": "object",
      "properties": {
        "_key": {
          "pattern": "^ENSG[0-9]{11}(?:_PAR_Y)?$",
          "example": "ENSG00000290825"
        },
        "gene_id": {
          "type": "string",
          "description": "The unique ENSEMBL gene ID with version number",
          "example": "ENSG00000290825.1",
          "pattern": "^ENSG[0-9]{11}\\.[0-9]+(?:_PAR_Y)?$"
        },
        "gene_type": {
          "type": "string",
          "description": "The type of gene",
          "enum": [
            "artifact",
            "IG_C_gene",
            "IG_C_pseudogene",
            "IG_D_gene",
            "IG_J_gene",
            "IG_J_pseudogene",
            "IG_pseudogene",
            "IG_V_gene",
            "IG_V_pseudogene",
            "lncRNA",
            "miRNA",
            "misc_RNA",
            "Mt_rRNA",
            "Mt_tRNA",
            "processed_pseudogene",
            "protein_coding",
            "pseudogene",
            "ribozyme",
            "rRNA",
            "rRNA_pseudogene",
            "scaRNA",
            "scRNA",
            "snoRNA",
            "snRNA",
            "sRNA",
            "TEC",
            "TR_C_gene",
            "TR_D_gene",
            "TR_J_gene",
            "TR_J_pseudogene",
            "TR_V_gene",
            "TR_V_pseudogene",
            "transcribed_processed_pseudogene",
            "transcribed_unitary_pseudogene",
            "transcribed_unprocessed_pseudogene",
            "translated_processed_pseudogene",
            "translated_unprocessed_pseudogene",
            "unitary_pseudogene",
            "unprocessed_pseudogene",
            "vault_RNA"
          ]
        },
        "chr": {
          "type": "string",
          "description": "The chromosome name",
          "example": "chr9",
          "pattern": "^chr"
        },
        "start": {
          "type": "number",
          "description": "The start position of the gene",
          "example": 11869
        },
        "end": {
          "type": "number",
          "description": "The end position of the gene",
          "example": 14409
        },
        "strand": {
          "type": "string",
          "description": "The strand of the gene",
          "enum": [
            "+",
            "-"
          ]
        },
        "name": {
          "example": "DDX11L2"
        },
        "symbol": {
          "type": "string",
          "description": "The symbol of the gene",
          "example": "DDX11L2"
        },
        "source": {
          "enum": [
            "GENCODE"
          ]
        },
        "version": {
          "type": "string",
          "description": "The version of the gene annotation",
          "enum": [
            "v43"
          ]
        },
        "source_url": {
          "enum": [
            "https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_43/gencode.v43.chr_patch_hapl_scaff.annotation.gtf.gz"
          ]
        },
        "organism": {
          "type": "string",
          "description": "The organism of the gene",
          "enum": [
            "Homo sapiens"
          ]
        },
        "study_sets": {
          "type": [
            "array",
            "null"
          ],
          "description": "The study sets of the gene",
          "items": {
            "type": "string",
            "enum": [
              "16p11.2 Deletion - Shendure",
              "Blood Master Regulators",
              "Cardiac - Engreitz",
              "Cardiac - Munshi",
              "Cardiac - Quertermous",
              "Cardiometabolic TFs",
              "Cardiomyopathies-Steinmetz",
              "CdLS-like phenotype",
              "Coronary Artery Disease - Lettre",
              "DiGeorge Syndrome - Park",
              "DiGeorge Syndrome - Shendure",
              "GREGoR Candidate - BCM",
              "GREGoR Candidate - Broad",
              "GREGoR Candidate - GSS",
              "GREGoR Candidate - UW",
              "IGVFFI6537JARB",
              "IGVFFI7781XWZY",
              "LDL-C uptake",
              "MorPhiC",
              "Pancreatic differentiation",
              "Pulmonary arterial hypertension - Rabinovitch",
              "SGE-Starita",
              "Strong Selection - Sunyaev",
              "VAMP-seq",
              "Williams Syndrome - Park",
              "Williams Syndrome - Shendure"
            ]
          }
        },
        "collections": {
          "type": [
            "array",
            "null"
          ],
          "description": "The collections of the gene",
          "items": {
            "type": "string",
            "enum": [
              "ACMG73",
              "GREGoR",
              "Morphic",
              "StanfordFCC"
            ]
          }
        },
        "version_number": {
          "type": "string",
          "description": "The version number of the ENSEMBL gene ID",
          "example": "1"
        },
        "hgnc": {
          "type": "string",
          "description": "The HGNC ID of the gene",
          "example": "HGNC:100000",
          "pattern": "^HGNC:[0-9]+$"
        },
        "synonyms": {
          "type": "array",
          "description": "The synonyms of the gene",
          "items": {
            "type": "string"
          }
        },
        "entrez": {
          "type": "string",
          "description": "The Entrez ID of the gene",
          "example": "ENTREZ:100287102",
          "pattern": "^ENTREZ:[0-9]+$"
        }
      },
      "required": [
        "gene_id",
        "gene_type",
        "chr",
        "start",
        "end",
        "strand",
        "symbol",
        "version",
        "organism",
        "study_sets",
        "collections",
        "version_number"
      ]
    }
  ],
  "additionalProperties": false,
  "accessible_via": {
    "filter_by_range": "start, end",
    "simplified_return": "_id, chr, gene_id, hgnc, name, organism",
    "return": "_id, chr, start, end, gene_id, hgnc, name, gene_type, strand, source, version, source_url, synonyms, organism, entrez, collections, study_sets"
  }
}
