{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "schemas/nodes/files_filesets.FileFileSet.json",
  "allOf": [
    {
      "$ref": "node.base.json"
    },
    {
      "type": "object",
      "properties": {
        "_key": {
          "example": "ENCFF004PFU"
        },
        "name": {
          "example": "ENCFF004PFU"
        },
        "file_set_id": {
          "type": "string",
          "description": "The file set id of the file set",
          "example": "ENCFF004PFU"
        },
        "lab": {
          "type": "string",
          "description": "The lab of the file set",
          "enum": [
            "alan-boyle",
            "bill-majoros",
            "charles-gersbach",
            "doug-fowler",
            "j-michael-cherry",
            "jay-shendure",
            "jesse-engreitz",
            "karen-mohlke",
            "kushal-dey",
            "lea-starita",
            "mark-craven",
            "nadav-ahituv",
            "predrag-radivojac",
            "thomas-quertermous",
            "tim-reddy",
            "zhiping-weng"
          ]
        },
        "preferred_assay_titles": {
          "type": [
            "array",
            "null"
          ],
          "description": "The preferred assay titles of the file set",
          "items": {
            "type": "string",
            "enum": [
              "CRISPR FACS screen",
              "DNase-seq",
              "electroporated MPRA",
              "lentiMPRA",
              "MPRA",
              "Perturb-seq",
              "scATAC-seq",
              "SGE",
              "STARR-seq",
              "TAP-seq",
              "VAMP-seq",
              "VAMP-seq (MultiSTEP)",
              "Variant-EFFECTS"
            ]
          }
        },
        "assay_term_ids": {
          "type": [
            "array",
            "null"
          ],
          "description": "The assay term ids of the file set",
          "example": [
            "OBI:0002440"
          ],
          "items": {
            "type": "string"
          }
        },
        "method": {
          "type": "string",
          "description": "The method of the file set",
          "enum": [
            "BlueSTARR",
            "candidate Cis-Regulatory Elements",
            "caQTL",
            "CRISPR enhancer perturbation screen",
            "CRISPR FACS screen",
            "cV2F",
            "elements",
            "ENCODE-rE2G",
            "ESM-1v",
            "Homo sapiens elements",
            "MPRA",
            "MutPred2",
            "Perturb-seq",
            "SEMVAR",
            "SGE",
            "STARR-seq",
            "TAP-seq",
            "VAMP-seq",
            "VAMP-seq (MultiSTEP)",
            "Variant-EFFECTS",
            "scATAC-seq"
          ]
        },
        "class": {
          "type": "string",
          "description": "The class of the file set",
          "enum": [
            "biological relationship",
            "observed data",
            "prediction"
          ]
        },
        "software": {
          "type": [
            "array",
            "null"
          ],
          "description": "The software of the file set",
          "items": {
            "type": "string",
            "enum": [
              "2024_multistep",
              "BCalm",
              "BEDTools",
              "bigWigAverageOverBed",
              "BIRD",
              "BlueSTARR",
              "CountESS",
              "cV2F",
              "cyp2c19_2c9",
              "DESeq2",
              "Distal regulation ENCODE-rE2G",
              "DistalRegulationCRISPRdata",
              "Engreitz Variant-EFFECTS scripts",
              "ESM-1v",
              "FRACTEL",
              "MPRAflow tsv-to-bed",
              "mpralm",
              "MutPred2",
              "pandas",
              "Samtools",
              "scATAC-seq processing scripts",
              "SEMVAR",
              "Sceptre",
              "Seurat",
              "SGE Pipeline"
            ]
          }
        },
        "samples": {
          "type": [
            "array",
            "null"
          ],
          "description": "The samples of the file set",
          "example": [
            "ontology_terms/UBERON_0002048"
          ],
          "items": {
            "type": "string",
            "pattern": "^ontology_terms/[A-Z0-9_]+$"
          }
        },
        "sample_ids": {
          "type": [
            "array",
            "null"
          ],
          "description": "The sample ids of the file set",
          "example": [
            "ENCBS160ZPI",
            "ENCBS659PKW",
            "ENCBS825OJD"
          ],
          "items": {
            "type": "string"
          }
        },
        "simple_sample_summaries": {
          "type": [
            "array",
            "null"
          ],
          "description": "The simple sample summaries of the file set",
          "example": [
            "GM12878"
          ]
        },
        "donors": {
          "type": [
            "array",
            "null"
          ],
          "description": "The donors of the file set",
          "example": [
            "donors/ENCDO000AAK"
          ],
          "items": {
            "type": "string",
            "pattern": "^donors/[A-Z0-9]+$"
          }
        },
        "treatments_term_ids": {
          "type": [
            "array",
            "null"
          ],
          "description": "The treatments term ids of the file set",
          "example": [
            "CHEBI:15367"
          ]
        },
        "publication": {
          "type": [
            "string",
            "null"
          ],
          "description": "The publication of the file set",
          "example": "PMID:34017130"
        },
        "collections": {
          "type": "array",
          "items": {
            "type": "string",
            "minItems": 1
          },
          "description": "The collections of the file set",
          "example": [
            "genomic_elements"
          ]
        },
        "source": {
          "enum": [
            "ENCODE",
            "IGVF"
          ]
        },
        "source_url": {
          "example": "https://api.data.igvf.org/tabular-files/IGVFFI6913PEWI/"
        },
        "download_link": {
          "type": "string",
          "description": "The download link of the file",
          "example": "https://api.data.igvf.org/signal-files/IGVFFI8400FXRX/@@download/IGVFFI8400FXRX.bigWig"
        },
        "cell_annotation": {
          "type": [
            "string",
            "null"
          ],
          "description": "The cell annotation of the file set",
          "enum": [
            null,
            "extraembryonic parietal endodermal cell",
            "extraembryonic visceral endodermal cell",
            "intermediate extraembryonic parietal endodermal cell",
            "mesodermal cell",
            "neurectodermal cell",
            "pluripotent epiblast cell",
            "surface ectodermal cell"
          ]
        },
        "genome_browser_link": {
          "type": ["string", "null"],
          "description": "The genome browser link of the file set",
          "example": "https://api.data.igvf.org/signal-files/IGVFFI8400FXRX/@@download/IGVFFI8400FXRX.bigWig"
        }
      },
      "required": [
        "file_set_id",
        "lab",
        "preferred_assay_titles",
        "assay_term_ids",
        "method",
        "class",
        "software",
        "samples",
        "sample_ids",
        "simple_sample_summaries",
        "donors",
        "treatments_term_ids",
        "publication",
        "download_link",
        "cell_annotation"
      ],
      "additionalProperties": false
    }
  ],
  "accessible_via": {
    "return": "_id, file_set_id, lab, preferred_assay_titles, assay_term_ids, method, class, collections, software, samples, sample_ids, simple_sample_summaries, donors, treatments_term_ids, publication, source, source_url, download_link, cell_annotation, genome_browser_link"
  },
  "db_collection_name": "files_filesets"
}
