{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "edges/variants_proteins.ASB_GVATDB.json",
  "db_collection_name": "variants_proteins",
  "allOf": [
    {
      "$ref": "edges.base.json"
    },
    {
      "type": "object",
      "properties": {
        "_key": {
          "type": "string",
          "description": "Unique identifier for the variant to protein edge",
          "example": "NC_000003.12:12567078:C:G_ENSP00000368332_DBD_1_1_H2"
        },
        "_from": {
          "example": "variants/NC_000001.11:10000:T:A",
          "pattern": "^variants/",
          "collections": [
            "variants"
          ]
        },
        "_to": {
          "example": "proteins/ENSP00000456328",
          "pattern": "^proteins/",
          "collections": [
            "proteins"
          ]
        },
        "p_value": {
          "type": "number",
          "description": "The p-value of the variant to protein edge"
        },
        "log10pvalue": {
          "type": "number",
          "description": "The log10pvalue of the variant to protein edge"
        },
        "experiment": {
          "type": "string",
          "description": "The experiment of the variant to protein edge",
          "example": "DBD.1.1.H2"
        },
        "hg19_coordinate": {
          "type": "string",
          "description": "The hg19 coordinate of the variant to protein edge",
          "example": "chr10:114386719-114386759"
        },
        "oligo_auc": {
          "type": "number",
          "description": "The oligo auc of the variant to protein edge"
        },
        "oligo_pval": {
          "type": "number",
          "description": "The oligo pval of the variant to protein edge"
        },
        "ref_auc": {
          "type": "number",
          "description": "The ref auc of the variant to protein edge"
        },
        "alt_auc": {
          "type": "number",
          "description": "The alt auc of the variant to protein edge"
        },
        "pbs": {
          "type": "number",
          "description": "The pbs of the variant to protein edge"
        },
        "fdr": {
          "type": "number",
          "description": "The fdr of the variant to protein edge"
        },
        "source": {
          "enum": [
            "GVATdb"
          ]
        },
        "source_url": {
          "enum": [
            "https://renlab.sdsc.edu/GVATdb/"
          ]
        },
        "label": {
          "enum": [
            "allele-specific binding"
          ]
        },
        "method": {
          "enum": [
            "GVATdb"
          ]
        },
        "class": {
          "enum": [
            "observed data"
          ]
        },
        "name": {
          "enum": [
            "modulates binding of"
          ]
        },
        "inverse_name": {
          "enum": [
            "binding modulated by"
          ]
        },
        "biological_process": {
          "type": "string",
          "description": "The biological process of the variant to protein edge",
          "enum": [
            "ontology_terms/GO_0051101"
          ]
        }
      },
      "required": [
        "_key",
        "p_value",
        "log10pvalue",
        "experiment",
        "hg19_coordinate",
        "oligo_auc",
        "oligo_pval",
        "ref_auc",
        "alt_auc",
        "pbs",
        "fdr",
        "biological_process"
      ],
      "additionalProperties": false
    }
  ],
  "accessible_via": {
    "name": "variants_proteins",
    "return": "laebl, method, class, source, source_url, fdr, p_value, log10pvalue"
  }
}
