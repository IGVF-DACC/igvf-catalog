{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "edges/variants_proteins.ASB.json",
  "db_collection_name": "variants_proteins",
  "allOf": [
    {
      "$ref": "edges.base.json"
    },
    {
      "type": "object",
      "properties": {
        "_key": {
          "type": "string",
          "description": "Unique identifier for the variant to protein edge",
          "example": "NC_000015.10:75202391:C:G_ENSP00000281043_Concordant_ADASTRA_520"
        },
        "_from": {
          "example": "variants/NC_000004.12:11439934:A:G",
          "pattern": "^variants/",
          "collections": [
            "variants"
          ]
        },
        "_to": {
          "example": "proteins/ENSP00000227163",
          "pattern": "^proteins/",
          "collections": [
            "proteins"
          ]
        },
        "chr": {
          "type": "string",
          "description": "The chromosome of the variant to protein edge",
          "example": "chr10"
        },
        "rsid": {
          "type": "string",
          "description": "The rsid of the variant to protein edge",
          "example": "rs1234567890"
        },
        "motif_fc": {
          "type": "string",
          "description": "The motif fc of the variant to protein edge",
          "example": "-0.2727347850176788"
        },
        "motif_pos": {
          "type": "string",
          "description": "The motif pos of the variant to protein edge",
          "example": "10"
        },
        "motif_orient": {
          "type": "string",
          "description": "The motif orient of the variant to protein edge",
          "example": "+"
        },
        "motif_conc": {
          "type": "string",
          "description": "The motif conc of the variant to protein edge",
          "example": "No Hit"
        },
        "motif": {
          "type": "string",
          "description": "The motif of the variant to protein edge",
          "example": "motifs/TFDP1_HUMAN_HOCOMOCOv11",
          "pattern": "^motifs/"
        },
        "es_mean_ref": {
          "type": "string",
          "description": "The effect size mean for the reference allele",
          "example": "1.795276180193825"
        },
        "es_mean_alt": {
          "type": "string",
          "description": "The effect size mean for the alternate allele",
          "example": "-1.7019721868875686"
        },
        "fdrp_bh_ref": {
          "type": "string",
          "description": "The FDR-adjusted p-value (Benjamini-Hochberg) for the reference allele",
          "example": "0.0171981040581793"
        },
        "fdrp_bh_alt": {
          "type": "string",
          "description": "The FDR-adjusted p-value (Benjamini-Hochberg) for the alternate allele",
          "example": "1.0"
        },
        "biological_context": {
          "type": "string",
          "description": "The biological context (cell type name) of the variant to protein edge",
          "example": "Kelly (neuroblastoma)"
        },
        "biosample_term": {
          "type": "string",
          "description": "The biosample term (ontology term ID) of the variant to protein edge",
          "example": "ontology_terms/EFO_0002069",
          "pattern": "^ontology_terms/"
        },
        "source": {
          "enum": [
            "ADASTRA"
          ]
        },
        "source_url": {
          "example": "http://gtrd.biouml.org/#!table/gtrd_current.cells/Details/ID=520"
        },
        "label": {
          "enum": [
            "allele-specific binding"
          ]
        },
        "method": {
          "enum": [
            "ADASTRA"
          ]
        },
        "class": {
          "enum": [
            "observed data"
          ]
        },
        "name": {
          "enum": [
            "modulates binding of"
          ]
        },
        "inverse_name": {
          "enum": [
            "binding modulated by"
          ]
        },
        "biological_process": {
          "type": "string",
          "description": "The biological process of the variant to protein edge",
          "enum": [
            "ontology_terms/GO_0051101"
          ]
        }
      },
      "required": [
        "_key",
        "chr",
        "rsid",
        "motif_fc",
        "motif_pos",
        "motif_orient",
        "motif_conc",
        "motif",
        "es_mean_ref",
        "es_mean_alt",
        "fdrp_bh_ref",
        "fdrp_bh_alt",
        "biological_context",
        "biosample_term",
        "biological_process"
      ],
      "additionalProperties": false
    }
  ],
  "accessible_via": {
    "simplified_return": "motif, source",
    "return": "motif, motif_fc, fdrp_bh_ref, fdrp_bh_alt, biological_context, label, biosample_term, source, source_url, method, class"
  }
}
