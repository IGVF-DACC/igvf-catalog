{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/edges/genes_genes.Coxpresdb.json",
  "allOf": [
    { "$ref": "edges.base.json" },
    {
      "type": "object",
      "properties": {
        "_key": {
          "type": "string",
          "description": "The unique key of the gene gene edge",
          "example": "80185_2222_coxpresdb"
        },
        "_from": {
          "type": "string",
          "description": "The from node of the gene gene edge",
          "example": "genes/ENSG00000129696",
          "pattern": "^genes/ENSG[0-9]{11}(?:_PAR_Y)?$",
          "collections": ["genes"]
        },
        "_to": {
          "type": "string",
          "description": "The to node of the gene gene edge",
          "example": "genes/ENSG00000129696",
          "pattern": "^genes/ENSG[0-9]{11}(?:_PAR_Y)?$",
          "collections": ["genes"]
        },
        "z_score": {
          "type": "number",
          "description": "The z score of the gene gene edge",
          "example": 1.23
        },
        "associated process": {
          "type": "string",
          "description": "The associated process of the gene gene edge",
          "enum": ["ontology_terms/GO_0010467"]
        },
        "method": {
          "enum": ["COXPRESdb"]
        },
        "class": {
          "enum": ["observed data"]
        },
        "label": {
          "enum": ["co-expression"]
        },
        "source": {
          "enum": ["COXPRESdb"]
        },
        "source_url": {
          "enum": ["https://coxpresdb.jp/"]
        },
        "name": {
          "enum": ["coexpressed with"]
        },
        "inverse_name": {
          "enum": ["coexpressed with"]
        }
      },
      "required": ["_key", "z_score", "associated process"],
      "additionalProperties": false,
      "accessible_via": {
        "filter_by_range": "z_score",
        "return": "z_score, source, source_url, method, class, label"
      }
    }
  ],
  "db_collection_name": "genes_genes"
}
