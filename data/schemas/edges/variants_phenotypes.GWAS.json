{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "edges/variants_phenotypes.GWAS.json",
  "db_collection_name": "variants_phenotypes",
  "type": "object",
  "allOf": [
    { "$ref": "edges.base.json" }
  ],
  "properties": {
    "source_url": false,
    "equivalent_ontology_term": {
      "type": [
        "string",
        "null"
      ],
      "description": "Equivalent ontology term for the variant to phenotype edge",
      "example": "ontology_terms/GO_0008150"
    }
  },
  "required": [
    "_from",
    "_to",
    "label",
    "class",
    "method",
    "name",
    "inverse_name",
    "source",
    "source_url",
    "equivalent_ontology_term"
  ],
  "additionalProperties": false
}
