{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "edges/variants_phenotypes.GWAS.json",
  "db_collection_name": "variants_phenotypes",
  "type": "object",
  "allOf": [
    { "$ref": "edges.base.json" },
    {
      "type": "object",
      "properties": {
        "equivalent_ontology_term": {
          "type": ["string", "null"],
          "description": "Equivalent ontology term for the variant to phenotype edge",
          "example": "ontology_terms/GO_0008150"
        },
        "class": {
          "enum": [
            "observed data"
          ]
        },
        "method": {
          "enum": [
            "GWAS"
          ]
        },
        "label": {
          "enum": [
            "GWAS"
          ]
        },
        "source": {
          "enum": [
            "OpenTargets"
          ]
        },
        "source_url": {
          "enum": [
            "https://data.igvf.org/reference-files/IGVFFI1309WDQG"
          ]
        },
        "name": {
          "enum": [
            "associated with"
          ]
        },
        "inverse_name": {
          "enum": [
            "associated with"
          ]
        },
        "version": {
          "type": "string",
          "description": "Version of the data source",
          "example": "October 2022 (22.10)"
        },
        "_key": {
          "type": "string",
          "description": "Unique identifier for the edge, generated as a hash of the source and target node IDs",
          "example": "d290f1ee-6c54-4b01-90e6-d701748f0851"
        }
      },
      "required": [
        "equivalent_ontology_term",
        "version",
        "_key"
      ]
    }
  ],
  "additionalProperties": false,
  "accessible_via": {
    "return": "method, label, class, source, source_url, equivalent_ontology_term, version, name, inverse_name"
  },
  "db_collection_name": "variants_phenotypes"
}
