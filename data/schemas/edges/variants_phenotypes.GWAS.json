{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "edges/variants_phenotypes.GWAS.json",
  "db_collection_name": "variants_phenotypes",
  "type": "object",
  "allOf": [
    { "$ref": "edges.base.json" },
    {
      "type": "object",
      "properties": {
        "equivalent_ontology_term": {
          "type": ["string", "null"],
          "description": "Equivalent ontology term for the variant to phenotype edge",
          "example": "ontology_terms/GO_0008150"
        },
        "lead_chrom": {
          "type": "string",
          "description": "Lead chromosome for the variant to phenotype edge",
          "example": "1"
        },
        "lead_pos": {
          "type": "number",
          "description": "Lead position for the variant to phenotype edge",
          "example": 10000
        },
        "lead_ref": {
          "type": "string",
          "description": "Lead reference for the variant to phenotype edge",
          "example": "A"
        },
        "lead_alt": {
          "type": "string",
          "description": "Lead alternative for the variant to phenotype edge",
          "example": "G"
        },
        "phenotype_term": {
          "type": ["string", "null"],
          "description": "Phenotype term for the variant to phenotype edge",
          "example": "chronic obstructive pulmonary disease"
        },
        "direction": {
          "type": "string",
          "description": "Direction for the variant to phenotype edge",
          "example": "+"
        },
        "beta": {
          "type": "number",
          "description": "Beta for the variant to phenotype edge",
          "example": 0.01
        },
        "beta_ci_lower": {
          "type": "number",
          "description": "Beta CI lower for the variant to phenotype edge",
          "example": 0.005
        },
        "beta_ci_upper": {
          "type": "number",
          "description": "Beta CI upper for the variant to phenotype edge",
          "example": 0.015
        },
        "odds_ratio": {
          "type": "number",
          "description": "Odds ratio for the variant to phenotype edge",
          "example": 1.5
        },
        "oddsr_ci_lower": {
          "type": "number",
          "description": "Odds ratio CI lower for the variant to phenotype edge",
          "example": 1.2
        },
        "oddsr_ci_upper": {
          "type": "number",
          "description": "Odds ratio CI upper for the variant to phenotype edge",
          "example": 1.8
        },
        "p_val_mantissa": {
          "type": "number",
          "description": "P value mantissa for the variant to phenotype edge",
          "example": 0.01
        },
        "p_val_exponent": {
          "type": "number",
          "description": "P value exponent for the variant to phenotype edge",
          "example": 10
        },
        "p_val": {
          "type": "number",
          "description": "P value for the variant to phenotype edge",
          "example": 0.01
        },
        "log10pvalue": {
          "type": "number",
          "description": "Log10pvalue for the variant to phenotype edge",
          "example": 1
        },
        "tagged_variants": {
          "type": "array",
          "description": "Tagged variants for the variant to phenotype edge",
          "example": [
            {
              "tag_chrom": "1",
              "tag_pos": 16964110,
              "tag_ref": "TTTTTC",
              "tag_alt": "T",
              "overall_r2": "0.68343289",
              "pics_95perc_credset": "False",
              "AFR_1000G_prop": "0.25",
              "AMR_1000G_prop": "0.25",
              "EAS_1000G_prop": "0.25",
              "EUR_1000G_prop": "0.25",
              "SAS_1000G_prop": "0.0",
              "log10_ABF": "NA",
              "posterior_prob": "NA"
            }
          ]
        },
        "class": {
          "enum": [
            "observed data"
          ]
        },
        "method": {
          "enum": [
            "GWAS"
          ]
        },
        "label": {
          "enum": [
            "GWAS"
          ]
        },
        "source": {
          "enum": [
            "OpenTargets"
          ]
        },
        "source_url": {
          "enum": [
            "https://data.igvf.org/reference-files/IGVFFI1309WDQG"
          ]
        },
        "name": {
          "enum": [
            "associated with"
          ]
        },
        "inverse_name": {
          "enum": [
            "associated with"
          ]
        },
        "version": {
          "type": "string",
          "description": "Version of the data source",
          "example": "October 2022 (22.10)"
        },
        "_key": {
          "type": "string",
          "description": "Unique identifier for the edge, generated as a hash of the source and target node IDs",
          "example": "d290f1ee-6c54-4b01-90e6-d701748f0851"
        },
        "study": {
          "type": "string",
          "description": "Studies ID for the variant to phenotype edge",
          "example": "studies/GCST006368"
        }
      },
      "required": [
        "equivalent_ontology_term",
        "lead_chrom",
        "lead_pos",
        "lead_ref",
        "lead_alt",
        "phenotype_term",
        "direction",
        "beta",
        "beta_ci_lower",
        "beta_ci_upper",
        "odds_ratio",
        "oddsr_ci_lower",
        "oddsr_ci_upper",
        "p_val_mantissa",
        "p_val_exponent",
        "p_val",
        "log10pvalue",
        "tagged_variants",
        "version",
        "_key",
        "study"
      ]
    }
  ],
  "additionalProperties": false,
  "accessible_via": {
    "filter_by_range": "log10pvalue",
    "return": "_from, lead_chrom, lead_pos, lead_ref, lead_alt, phenotype_term, direction, beta, beta_ci_lower, beta_ci_upper, p_val_mantissa, p_val_exponent, p_val, log10pvalue, oddsr_ci_lower, oddsr_ci_upper"
  }
}
