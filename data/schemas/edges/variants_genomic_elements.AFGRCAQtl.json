{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/edges/variants_genomic_elements.AFGRCAQtl.json",
  "allOf": [
    {
      "$ref": "edges.base.json"
    },
    {
      "type": "object",
      "properties": {
        "_key": {
          "type": "string",
          "description": "Unique identifier for the variant to genomic element edge",
          "example": "NC_000001.11:903006:T:C_accessible_dna_element_1_906596_907043_GRCh38_AFGR"
        },
        "_from": {
          "example": "variants/NC_000001.11:903006:T:C",
          "pattern": "^variants/",
          "collections": [
            "variants"
          ]
        },
        "_to": {
          "example": "genomic_elements/accessible_dna_element_1_906596_907043_GRCh38_AFGR",
          "pattern": "^genomic_elements/",
          "collections": [
            "genomic_elements"
          ]
        },
        "label": {
          "enum": [
            "caQTL"
          ]
        },
        "log10pvalue": {
          "type": "number",
          "description": "Log10pvalue of the variant to genomic element edge"
        },
        "p_value": {
          "type": "number",
          "description": "Pvalue of the variant to genomic element edge"
        },
        "beta": {
          "type": "number",
          "description": "Beta of the variant to genomic element edge"
        },
        "source": {
          "enum": [
            "AFGR"
          ]
        },
        "source_url": {
          "enum": [
            "https://github.com/smontgomlab/AFGR"
          ]
        },
        "biological_context": {
          "type": "string",
          "description": "Biological context of the variant to genomic element edge",
          "enum": [
            "lymphoblastoid cell line"
          ]
        },
        "biosample_term": {
          "type": "string",
          "description": "Biosample term of the variant to genomic element edge",
          "enum": [
            "ontology_terms/EFO_0005292"
          ]
        },
        "name": {
          "enum": [
            "modulates accessibility of"
          ]
        },
        "inverse_name": {
          "enum": [
            "accessibility modulated by"
          ]
        },
        "method": {
          "enum": [
            "caQTL"
          ]
        },
        "class": {
          "enum": [
            "observed data"
          ]
        }
      },
      "required": [
        "_key",
        "log10pvalue",
        "p_value",
        "beta",
        "biological_context",
        "biosample_term"
      ],
      "additionalProperties": false
    }
  ],
  "db_collection_name": "variants_genomic_elements",
  "accessible_via": {
    "filter_by_range": "log10pvalue, p_value, beta",
    "return": "log10pvalue, p_value, beta, source, label, source_url, biological_context, biosample_term, name, inverse_name, method"
  }
}
