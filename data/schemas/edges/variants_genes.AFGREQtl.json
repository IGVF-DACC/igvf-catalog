{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/edges/variants_genes.AFGREQtl.json",
  "allOf": [
    {
      "$ref": "edges.base.json"
    },
    {
      "type": "object",
      "properties": {
        "_key": {
          "type": "string",
          "description": "Unique identifier for the variant to gene edge"
        },
        "_from": {
          "example": "variants/NC_000001.11:10000:T:A",
          "pattern": "^variants/",
          "collections": [
            "variants"
          ]
        },
        "_to": {
          "example": "genes/ENSG00000187583.10",
          "pattern": "^genes/ENSG[0-9]{11}(?:_PAR_Y)?$",
          "collections": [
            "genes"
          ]
        },
        "biological_context": {
          "type": "string",
          "description": "Biological context for the variant to gene edge",
          "enum": [
            "lymphoblastoid cell line"
          ]
        },
        "biosample_term": {
          "type": "string",
          "description": "Biosample term for the variant to gene edge",
          "enum": [
            "ontology_terms/EFO_0005292"
          ]
        },
        "chr": {
          "type": "string",
          "description": "Chromosome for the variant to gene edge",
          "example": "chr1",
          "pattern": "^chr"
        },
        "log10pvalue": {
          "type": "number",
          "description": "Log10pvalue for the variant to gene edge"
        },
        "p_value": {
          "type": "number",
          "description": "Pvalue for the variant to gene edge"
        },
        "effect_size": {
          "type": "number",
          "description": "Effect size for the variant to gene edge"
        },
        "class": {
          "enum": [
            "observed data"
          ]
        },
        "method": {
          "enum": [
            "eQTL"
          ]
        },
        "label": {
          "enum": [
            "eQTL"
          ]
        },
        "source": {
          "enum": [
            "AFGR"
          ]
        },
        "source_url": {
          "enum": [
            "https://github.com/smontgomlab/AFGR"
          ]
        },
        "name": {
          "enum": [
            "modulates expression of"
          ]
        },
        "inverse_name": {
          "enum": [
            "expression modulated by"
          ]
        },
        "biological_process": {
          "type": "string",
          "description": "Biological process for the variant to gene edge",
          "enum": [
            "ontology_terms/GO_0010468"
          ]
        }
      },
      "required": [
        "_key",
        "chr",
        "log10pvalue",
        "p_value",
        "effect_size",
        "biological_context",
        "biosample_term",
        "biological_process"
      ],
      "additionalProperties": false
    }
  ],
  "db_collection_name": "variants_genes",
  "accessible_via": {
    "filter_by_range": "log10pvalue, effect_size",
    "simplified_return": "class, method, label, source, log10pvalue, biological_context",
    "return": "chr, log10pvalue, p_value, effect_size, source, class, method, label, source_url, biological_context"
  }
}
