{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/edges/variants_genes.AFGRSQtl.json",
  "allOf": [
    {
      "$ref": "edges.base.json"
    },
    {
      "type": "object",
      "properties": {
        "_key": {
          "type": "string",
          "description": "Unique identifier for the variant to gene edge"
        },
        "_from": {
          "example": "variants/NC_000001.11:10000:T:A",
          "pattern": "^variants/",
          "collections": [
            "variants"
          ]
        },
        "_to": {
          "example": "genes/ENSG00000187583.10",
          "pattern": "^genes/ENSG[0-9]{11}(?:_PAR_Y)?$",
          "collections": [
            "genes"
          ]
        },
        "biological_context": {
          "type": "string",
          "description": "Biological context for the variant to gene edge",
          "enum": [
            "lymphoblastoid cell line"
          ]
        },
        "biosample_term": {
          "type": "string",
          "description": "Biosample term for the variant to gene edge",
          "enum": [
            "ontology_terms/EFO_0005292"
          ]
        },
        "chr": {
          "type": "string",
          "description": "Chromosome for the variant to gene edge",
          "example": "chr1",
          "pattern": "^chr"
        },
        "log10pvalue": {
          "type": "number",
          "description": "Log10pvalue for the variant to gene edge"
        },
        "p_value": {
          "type": "number",
          "description": "Pvalue for the variant to gene edge"
        },
        "effect_size": {
          "type": "number",
          "description": "Effect size for the variant to gene edge"
        },
        "class": {
          "enum": [
            "observed data"
          ]
        },
        "method": {
          "enum": [
            "splice_QTL"
          ]
        },
        "label": {
          "enum": [
            "splice_QTL"
          ]
        },
        "intron_chr": {
          "type": "string",
          "description": "Intron chromosome for the variant to gene edge",
          "example": "chr1",
          "pattern": "^chr"
        },
        "intron_start": {
          "type": "string",
          "description": "Intron start for the variant to gene edge"
        },
        "intron_end": {
          "type": "string",
          "description": "Intron end for the variant to gene edge"
        },
        "source": {
          "enum": [
            "AFGR"
          ]
        },
        "source_url": {
          "enum": [
            "https://github.com/smontgomlab/AFGR"
          ]
        },
        "name": {
          "enum": [
            "modulates splicing of"
          ]
        },
        "inverse_name": {
          "enum": [
            "splicing modulated by"
          ]
        },
        "biological_process": {
          "type": "string",
          "description": "Biological process for the variant to gene edge",
          "enum": [
            "ontology_terms/GO_0043484"
          ]
        }
      },
      "required": [
        "_key",
        "chr",
        "log10pvalue",
        "p_value",
        "effect_size",
        "biological_context",
        "biosample_term",
        "biological_process",
        "intron_chr",
        "intron_start",
        "intron_end"
      ],
      "additionalProperties": false
    }
  ],
  "accessible_via": {
    "filter_by_range": "intron_start, intron_end, log10pvalue, effect_size",
    "simplified_return": "class, method, label, source, log10pvalue, biological_context",
    "return": "intron_chr, intron_start, intron_end, effect_size, log10pvalue, source, class, method, label, p_value, chr, source_url, biological_context, biosample_term"
  },
  "db_collection_name": "variants_genes"
}
